# ===== Required =====
# Local MongoDB (or any Mongo connection string)
MONGO_URL=mongodb://localhost:27017
DB_NAME=portfolio

# Public base URL of your deployed site
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=*

# ===== Email notifications (Resend) =====
# Get a free API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_RECIPIENT_EMAIL=you@example.com

# ===== Admin dashboard =====
# Used to log in at /admin
ADMIN_PASSWORD="choose-a-strong-password"
# Random secret used to sign admin auth tokens
ADMIN_TOKEN_SECRET=replace-with-a-long-random-string
